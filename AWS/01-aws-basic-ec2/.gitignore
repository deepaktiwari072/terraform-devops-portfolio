# Create the .gitignore file
# Terraform files
.terraform/
*.tfstate
*.tfstate.*
.terraform.lock.hcl
override.tf
override.tf.json
*.tfvars
*.tfvars.json

# Crash log files
crash.log
crash.*.log

# Local .terraform directories
**/.terraform/*

# Lock files (might be platform-specific)
.terraform.lock.hcl

# CLI configuration files
.terraformrc
terraform.rc

# Provider binaries
terraform-provider-*
*.exe
*.exe~

# OS specific files
.DS_Store
Thumbs.db

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# Your MFA script (if it contains credentials)
aws-mfa.sh
EOF
